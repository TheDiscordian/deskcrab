#!/usr/bin/env python3
"""Extract the final response text from DeskCrab's debug log."""

import json
import os
import sys

LOG = os.environ["DESKCRAB_DEBUGLOG"]

result_text = ""
last_assistant_text = ""
for line in open(LOG):
    line = line.strip()
    if not line:
        continue
    try:
        d = json.loads(line)
    except json.JSONDecodeError:
        continue
    if d.get("type") == "result" and d.get("result"):
        result_text = d["result"]
    elif d.get("type") == "assistant":
        for block in d.get("message", {}).get("content", []):
            if block.get("type") == "text" and block.get("text", "").strip():
                last_assistant_text = block["text"].strip()
print(result_text or last_assistant_text)
